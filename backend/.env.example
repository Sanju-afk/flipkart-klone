# ───────────────────────────────────────────────────
# Supabase Postgres Connection String
# ───────────────────────────────────────────────────
# Get this from your Supabase Dashboard → Connect button
#
# Option 1 (recommended for server apps) — SESSION POOLER (port 5432):
#   postgresql://postgres.xxxxxxxx:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
#
# Option 2 (for serverless functions) — TRANSACTION POOLER (port 6543):
#   postgresql://postgres.xxxxxxxx:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
#
# Your region ID may differ (us-east-1, ap-south-1, etc.)
# Replace [password] with your actual database password.
# ───────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres.xxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# Backend server port (optional, defaults to 5000)
PORT=5000
